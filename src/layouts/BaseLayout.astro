---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "医療セクターの株・優待情報を薬剤師・FP2級の視点で集約するサイト" } = Astro.props;
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const isProd = import.meta.env.PROD;
const fullTitle = `${title} | くすりの株ノート`;
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL('/ogp.png', Astro.site ?? 'https://kusuri-kabu-note.com').href;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{fullTitle}</title>

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="くすりの株ノート" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <slot name="head" />
    {isProd && GA_ID && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script define:vars={{ GA_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_ID);
        </script>
      </Fragment>
    )}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand" aria-label="くすりの株ノート トップへ">
        <svg width="30" height="30" viewBox="0 0 32 32" role="img" aria-hidden="true">
          <g transform="rotate(-40 16 16)">
            <rect x="5" y="12.5" width="22" height="9" rx="4.5" fill="#2c7a7b" />
            <rect x="16" y="12.5" width="11" height="9" rx="4.5" fill="#5fb0b1" />
            <rect x="15.2" y="12.5" width="1.6" height="9" fill="#ffffff" />
          </g>
        </svg>
        くすりの株ノート
      </a>
      <nav>
        <a href="/">トップ</a>
        <a href="/articles">記事一覧</a>
        <a href="/stocks">銘柄一覧</a>
        <a href="/about">運営者情報</a>
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/disclaimer">免責事項</a>
        <a href="/contact">お問い合わせ</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>本サイトはアフィリエイト広告を含みます。</p>
      <p>本サイトは情報提供を目的とし、投資助言業に該当する個別銘柄の推奨・売買指示・ポートフォリオ構成助言を行うものではありません。投資判断はご自身の責任において行ってください。</p>
      <p>運営者：薬剤師 / ファイナンシャル・プランニング技能士2級</p>
      <nav>
        <a href="/">トップ</a>
        <a href="/articles">記事一覧</a>
        <a href="/stocks">銘柄一覧</a>
        <a href="/about">運営者情報</a>
        <a href="/privacy">プライバシーポリシー</a>
        <a href="/disclaimer">免責事項</a>
        <a href="/contact">お問い合わせ</a>
      </nav>
      <p>&copy; {new Date().getFullYear()} くすりの株ノート</p>
    </footer>
  </body>
</html>
