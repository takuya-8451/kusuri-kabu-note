---
import { getCollection } from 'astro:content';
import BaseLayout from "../layouts/BaseLayout.astro";
import { categoryHref, CATEGORY_ORDER } from '../lib/categories';

const articles = await getCollection('articles');
const stocks = await getCollection('stocks');
const latestArticles = articles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5);
// 注目記事：GSC/GA4で読まれている（直帰率が低い・検索順位が出ている）実証済みの比較記事を手前に出す。
const FEATURED_IDS = [
  'drugstore-yutai-4sha-hikaku',
  'iryo-kiki-haitou-hikaku',
  'seiyaku-haitou-seikou-hikaku',
  'drugstore-haitou-2sha-hikaku',
];
const featuredArticles = FEATURED_IDS
  .map((id) => articles.find((a) => a.id === id))
  .filter((a) => a !== undefined);
const usedCategories = CATEGORY_ORDER.filter((c) =>
  articles.some((a) => a.data.category === c),
);
const stockCount = stocks.length;
---

<BaseLayout title="トップ">
  <section class="hero">
    <h1>くすりの株ノート</h1>
    <p class="lead">
      製薬・医療機器・調剤・ドラッグストアなど<strong>医療セクターの配当・優待情報</strong>を、
      <strong>薬剤師・FP2級・医療法人事務長</strong>の視点で集約するデータベースサイトです。
    </p>
    <p class="note">
      薬価改定・調剤報酬・医薬品供給といった制度の動きを、現場で関わってきた立場から読み解きます。
      個別銘柄の売買推奨・ポートフォリオ助言は行っておりません。
    </p>
  </section>

  <section class="featured">
    <h2>注目の比較記事</h2>
    <ul class="featured-list">
      {featuredArticles.map((article) => (
        <li>
          <a class="featured-card" href={`/articles/${article.id}/`}>
            <span class="featured-title">{article.data.title}</span>
            <span class="featured-desc">{article.data.description}</span>
            <span class="featured-cat">{article.data.category}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="cta">
    <h2>医療セクター株データベース</h2>
    <p>主要{stockCount}銘柄の配当利回り・権利確定月をセクター別に整理。気になる銘柄から関連記事へもたどれます。</p>
    <p><a class="cta-link" href="/stocks/">配当利回りで見る医療株一覧 →</a></p>
  </section>

  <section>
    <h2>最新記事</h2>
    <ul class="article-list">
      {latestArticles.map((article) => (
        <li>
          <a href={`/articles/${article.id}/`}>{article.data.title}</a>
          <br />
          <small>
            <time datetime={article.data.publishDate.toISOString()}>
              {article.data.publishDate.toLocaleDateString('ja-JP')}
            </time>
            　<a href={categoryHref(article.data.category)}>{article.data.category}</a>
          </small>
        </li>
      ))}
    </ul>
    <p><a href="/articles/">記事一覧をすべて見る →</a></p>
  </section>

  <section>
    <h2>カテゴリから探す</h2>
    <ul class="cat-links">
      {usedCategories.map((c) => (
        <li><a href={categoryHref(c)}>{c}</a></li>
      ))}
    </ul>
  </section>

  <section class="about">
    <h2>運営者について</h2>
    <p>
      運営者は薬剤師・FP2級・医療法人事務長。調剤現場での薬価・在庫・供給対応の経験と、
      ファイナンシャル・プランニングの知識をかけ合わせ、医療セクター株を「制度」と「現場」の両面から読み解きます。
    </p>
    <p><a href="/about/">運営者情報をくわしく見る →</a></p>
  </section>

  <p class="disclaimer-note">
    ※本サイトは情報提供を目的とし、投資助言業に該当する個別銘柄の推奨・売買指示・ポートフォリオ構成助言を行うものではありません。投資判断はご自身の責任において行ってください。
  </p>

  <style>
    .hero { margin-bottom: 1.5rem; }
    .hero h1 { margin-bottom: 0.5rem; }
    .lead { font-size: 1.1rem; line-height: 1.8; }
    .note { color: #555; font-size: 0.95rem; }
    .featured { margin: 1.5rem 0; }
    .featured-list { list-style: none; padding-left: 0; display: grid; gap: 0.75rem; }
    @media (min-width: 600px) {
      .featured-list { grid-template-columns: 1fr 1fr; }
    }
    .featured-card {
      display: block;
      height: 100%;
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 0.9rem 1rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .featured-card:hover {
      border-color: #2c7a7b;
      box-shadow: 0 2px 8px rgba(44, 122, 123, 0.12);
    }
    .featured-title { display: block; font-weight: bold; color: #1a5d5e; line-height: 1.5; }
    .featured-desc { display: block; margin-top: 0.4rem; font-size: 0.85rem; color: #555; line-height: 1.6; }
    .featured-cat {
      display: inline-block;
      margin-top: 0.5rem;
      padding: 0.1rem 0.6rem;
      background: #f0fafa;
      border: 1px solid #b2d8d8;
      border-radius: 999px;
      font-size: 0.75rem;
      color: #2c7a7b;
    }
    .cta {
      border: 1px solid #b2d8d8;
      background: #f0fafa;
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0;
    }
    .cta h2 { margin-top: 0; }
    .cta-link {
      display: inline-block;
      margin-top: 0.25rem;
      padding: 0.5rem 1rem;
      background: #2c7a7b;
      color: #fff;
      border-radius: 4px;
      text-decoration: none;
      font-weight: bold;
    }
    .cta-link:hover { background: #1a5d5e; }
    .article-list li { margin-bottom: 0.5rem; }
    .cat-links { list-style: none; padding-left: 0; }
    .cat-links li { display: inline-block; margin: 0 0.5rem 0.5rem 0; }
    .cat-links a {
      display: inline-block;
      padding: 0.25rem 0.85rem;
      border: 1px solid #ccc;
      border-radius: 999px;
      text-decoration: none;
      font-size: 0.9rem;
    }
    .cat-links a:hover { border-color: #2c7a7b; color: #2c7a7b; }
    .about { border-top: 1px solid #eee; margin-top: 2rem; padding-top: 1rem; color: #333; }
    .disclaimer-note { font-size: 0.8rem; color: #777; margin-top: 2rem; }
  </style>
</BaseLayout>
