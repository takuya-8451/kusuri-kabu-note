---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateBlock from '../../components/AffiliateBlock.astro';
import AffiliateBlockPharmacist from '../../components/AffiliateBlockPharmacist.astro';
import { categoryHref } from '../../lib/categories';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// この記事の relatedStocks のうち、銘柄ページが存在するものだけリンク化する
const stocks = await getCollection('stocks');
const stockByTicker = new Map(stocks.map((s) => [s.data.ticker, s.data]));
const relatedStocks = (article.data.relatedStocks ?? [])
  .map((ticker) => stockByTicker.get(ticker))
  .filter((s) => s !== undefined);

// 同じカテゴリの記事を新しい順に最大3件（自分自身は除外）
const allArticles = await getCollection('articles');
const relatedArticles = allArticles
  .filter((a) => a.id !== article.id && a.data.category === article.data.category)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

// 構造化データ（schema.org JSON-LD）：記事=BlogPosting＋パンくず
const siteUrl = Astro.site ?? new URL('https://kusuri-kabu-note.com');
const articleUrl = new URL(`/articles/${article.id}/`, siteUrl).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: article.data.title,
      description: article.data.description,
      datePublished: article.data.publishDate.toISOString(),
      dateModified: (article.data.updateDate ?? article.data.publishDate).toISOString(),
      author: { '@type': 'Person', name: 'アロ', url: new URL('/about/', siteUrl).href },
      publisher: { '@type': 'Organization', name: 'くすりの株ノート', url: siteUrl.href },
      mainEntityOfPage: articleUrl,
      inLanguage: 'ja',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'トップ', item: siteUrl.href },
        { '@type': 'ListItem', position: 2, name: article.data.category, item: new URL(categoryHref(article.data.category), siteUrl).href },
        { '@type': 'ListItem', position: 3, name: article.data.title, item: articleUrl },
      ],
    },
  ],
};
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <header>
      <h1>{article.data.title}</h1>
      <p>
        カテゴリ：<a href={categoryHref(article.data.category)}>{article.data.category}</a>
      </p>
      <p>
        公開日：<time datetime={article.data.publishDate.toISOString()}>
          {article.data.publishDate.toLocaleDateString('ja-JP')}
        </time>
        {article.data.updateDate && (
          <>
            　更新日：<time datetime={article.data.updateDate.toISOString()}>
              {article.data.updateDate.toLocaleDateString('ja-JP')}
            </time>
          </>
        )}
      </p>
    </header>

    <Content />

    {relatedStocks.length > 0 && (
      <section class="related-stocks">
        <h2>この記事で取り上げた銘柄</h2>
        <ul>
          {relatedStocks.map((s) => (
            <li>
              <a href={`/stocks/${s.ticker}/`}>{s.name}（{s.ticker}）</a>
              <small>　{s.sector}</small>
            </li>
          ))}
        </ul>
        <p><a href="/stocks/">医療セクター株一覧をすべて見る →</a></p>
      </section>
    )}

    {relatedArticles.length > 0 && (
      <section class="related-articles">
        <h2>同じカテゴリの記事</h2>
        <ul>
          {relatedArticles.map((a) => (
            <li>
              <a href={`/articles/${a.id}/`}>{a.data.title}</a>
            </li>
          ))}
        </ul>
        <p><a href={categoryHref(article.data.category)}>「{article.data.category}」の記事をすべて見る →</a></p>
      </section>
    )}

    <AffiliateBlock />
    {article.data.category === '制度解説' && <AffiliateBlockPharmacist />}

    <footer>
      <hr />
      <p><strong>免責事項：</strong>本記事は情報提供を目的としており、個別銘柄の売買推奨・目標株価の提示・ポートフォリオ構成助言など投資助言業に該当する情報提供は一切行いません。掲載データは各社IR等の一次情報をもとに運営者が整理したものです。情報の正確性・完全性を保証するものではなく、投資判断はご自身の責任において行ってください。</p>
    </footer>
  </article>

  <style>
    .related-stocks {
      border-top: 1px solid #ddd;
      margin-top: 2rem;
      padding-top: 1rem;
    }
    .related-stocks h2 {
      font-size: 1.1rem;
    }
    .related-stocks ul {
      padding-left: 1.25rem;
    }
    .related-stocks li {
      margin-bottom: 0.25rem;
    }
    .related-stocks small {
      color: #666;
    }
    .related-articles {
      border-top: 1px solid #ddd;
      margin-top: 2rem;
      padding-top: 1rem;
    }
    .related-articles h2 {
      font-size: 1.1rem;
    }
    .related-articles ul {
      padding-left: 1.25rem;
    }
    .related-articles li {
      margin-bottom: 0.25rem;
    }
  </style>
</BaseLayout>
